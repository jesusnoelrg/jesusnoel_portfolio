---
import TextShimmer from '@components/effects/TextShimmer.astro';
import SoftAurora from '@components/effects/SoftAurora.tsx';
const mi_stack = {
  nextjs: '../src/assets/icons/nextjs.svg',
  react: '../src/assets/icons/reactjs.svg',
  typescript: '../src/assets/icons/typescript.svg',
  tailwindcss: '../src/assets/icons/tailwindcss.svg',
  prisma: '../src/assets/icons/prisma.svg'
};
---

<section id="about" class="relative min-h-screen flex items-center justify-center py-40 md:py-20">
  <SoftAurora

      client:only="react"

      speed={0.6}
      scale={1}
      brightness={0.7}
      color1="#391d43"
      color2="#340481"
      noiseFrequency={2.5}
      noiseAmplitude={8}
      bandHeight={0.5}
      bandSpread={1}
      octaveDecay={0.1}
      layerOffset={0}
      colorSpeed={1}
      enableMouseInteraction
      mouseInfluence={0}
    />
  <div class="flex flex-col md:flex-row items-center justify-center mx-10 md:mx-20 lg:mx-30 xl:mx-40 z-10">
    <div class="md:w-2/3">
      <TextShimmer 
        id="pors"
        text="¿QUIÉN SOY?" 
        color1="#391d43" color2="#7d6187" color3="#391d43" 
        class="text-md lg:text-xl font-bold text-center md:text-start" 
      />
      <p class="text-3xl lg:text-5xl font-bold text-zinc-800 dark:text-zinc-300 mb-5 lg:mb-10 text-center md:text-start">Sobre mí</p>
      <div class="flex flex-col p-10  bg-(--bg-card) dark:bg-(--bg-card-dark) border border-zinc-300 dark:border-zinc-900 rounded-2xl">
        <div class="flex items-center gap-5">
          <img src="../src/assets/avatar.jpg" alt="Avatar" class="w-12 h-12 rounded-full" />
          <div>
            <p class="text-black dark:text-white">Jesús Noel Rabago Gocobachi</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">Desarrollador de Software | 22 años</p>
          </div>
        </div>
        <p class="text-[12px] lg:text-[15px] mt-5 leading-relaxed text-balance text-gray-800 dark:text-gray-300">
          Soy egresado de Ingeniería en Software con un enfoque obsesivo por la arquitectura de sistemas, la optimización de bases de datos y el desarrollo robusto en el Backend. Me apasiona destronar el código espagueti y diseñar soluciones eficientes y escalables utilizando tecnologías como Next.js, Node.js y Python.
          <br><br>
          Mi mentalidad está orientada a la autonomía y al rendimiento: desde liderar la infraestructura con Docker y Prisma en entornos universitarios, hasta optimizar la carga visual y el despliegue de plataformas en producción. No creo en las soluciones mágicas, sino en la ingeniería bien estructurada.
        </p>  
      </div>
    </div>
    <div class="md:w-1/3 flex flex-col items-center justify-center">
      <span class="text-lg font-bold text-gray-800 dark:text-gray-300 mt-10 md:mt-0">Mi stack favorito</span>
      <ul class="flex md:grid md:grid-cols-2 gap-4 mt-5">
          {Object.entries(mi_stack).map(([key, value]) => (
            <li class="
              p-3 rounded-2xl
            bg-(--bg-card) dark:bg-zinc-950 border border-zinc-300 dark:border-zinc-900
              dark:hover:bg-zinc-900 hover:scale-110 transition-all duration-200">
              <img src={value} alt={key} class="w-9 h-9  lg:w-12 lg:h-12" />
            </li>
          ))}
        </ul>
    </div>
  </div>
</section>
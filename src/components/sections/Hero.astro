---
import SoftAurora from '@components/effects/SoftAurora.tsx';
import TextShimmer from '@components/effects/TextShimmer.astro';

import Github from '@assets/icons/github.svg';
import LinkedIn from '@assets/icons/linkedin.svg';
import { Mail } from '@lucide/Astro';

---
<section class="
        relative 
        flex flex-col justify-center items-center
        my-40
        z-20
        text-black dark:text-white">

  <SoftAurora

      client:only="react"

      speed={0.6}
      scale={1}
      brightness={1}
      color1="#391d43"
      color2="#340481"
      noiseFrequency={2.5}
      noiseAmplitude={4}
      bandHeight={0.5}
      bandSpread={1}
      octaveDecay={0.1}
      layerOffset={0}
      colorSpeed={1}
      enableMouseInteraction
      mouseInfluence={0}
    />

  <div class="flex flex-col items-center justify-center container relative z-10">
    <div class="text-center gap-5">
      <p class="text-xl md:text-2xl lg:text-3xl text-black dark:text-white">¡Hola, soy Jesús Noel!</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-medium text-pretty leading-none text-black dark:text-white">
        Desarrollador de 
        <TextShimmer text="Software" color1="#391d43" color2="#7d6187" color3="#391d43" class="font-bold" />
      </h1>
      <p class="px-10 md:px-15 lg:px-35 xl:px-50 text-md md:text-2xl text-shadow-lg text-center leading-relaxed text-balance text-gray-800 dark:text-gray-300">
        Ingeniero de Software <span class="text-purple-400">enfocado</span> en arquitectura de sistemas, optimización 
        de bases de datos y aplicaciones de alto rendimiento.
      </p>
    </div>
    <nav aria-label="redes-sociales" class="mt-10">
      <ul class="flex gap-8">
        <li>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer"
            class="
            flex items-center justify-center p-3
            border border-zinc-300 dark:border-zinc-800 rounded-xl
            bg-zinc-100 dark:bg-zinc-950
            transition-all duration-200
            hover:scale-105 hover:bg-zinc-200 dark:hover:bg-zinc-900
            text-black dark:text-white"
          >
            <Github class="w-8 h-8 text-black dark:text-white" />
          </a>
        </li>
        <li>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer"
            class="
              flex items-center justify-center p-3
              border border-zinc-300 dark:border-zinc-800 rounded-xl
              bg-zinc-100 dark:bg-zinc-950
              transition-all duration-200
              hover:scale-105 hover:bg-zinc-200 dark:hover:bg-zinc-900
              text-black dark:text-white"
          >
            <LinkedIn class="w-8 h-8 text-black dark:text-white" />
          </a>
        </li>
        <li>
          <a href="mailto:jesusnoelrg.dev@gmail.com"
            class="
              flex items-center justify-center p-3
              border border-zinc-300 dark:border-zinc-800 rounded-xl
              bg-zinc-100 dark:bg-zinc-950
              transition-all duration-200
              hover:scale-105 hover:bg-zinc-200 dark:hover:bg-zinc-900
              text-black dark:text-white"
          >
            <Mail class="w-8 h-8 text-black dark:text-white" />
          </a>
        </li>
      </ul>
    </nav>
  </div>
</section>
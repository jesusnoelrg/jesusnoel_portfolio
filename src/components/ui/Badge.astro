---
const { url_img, text, className } = Astro.props;
---

<div class="
      flex items-center justify-center 
      px-3 py-1
      border border-zinc-300 dark:border-zinc-900 rounded-2xl
      text-sm 
      text-black dark:text-white bg-zinc-50 dark:bg-zinc-900 " >
  <img src={url_img} alt={text} class={`w-4 h-4 me-1 ${className}`} />
  {text}
</div>
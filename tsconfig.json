{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@my_stack/*": [
        "./src/assets/my_stack/*"
      ]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}